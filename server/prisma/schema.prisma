// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String?       @unique
  name         String?
  avatarUrl    String?
  isGuest      Boolean       @default(false)
  subjects     Subject[]
  habits       Habit[]
  toDo         ToDo[]
  dailyRatings DailyRating[]
  spaces       Space[]
  deleted      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum ToDoStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

model ToDo {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  status      ToDoStatus @default(PENDING)
  priority    Int        @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  deleted     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  toDoLog     ToDoLog[]

  @@index([userId])
  @@index([userId, deleted])
}

model ToDoLog {
  id        Int       @id @default(autoincrement())
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  toDo      ToDo      @relation(fields: [toDoId], references: [id], onDelete: Cascade)
  toDoId    Int

  @@index([toDoId])
  @@index([toDoId, deleted])
}

model Subject {
  id           Int          @id @default(autoincrement())
  name         String
  goalWorkSecs Int          @default(0)
  color        String       @default("#f97316")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  habits       Habit[]
  deleted      Boolean      @default(false)
  subjectLogs  SubjectLog[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, deleted])
}

model SubjectLog {
  id        Int       @id @default(autoincrement())
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  subjectId Int
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([subjectId])
  @@index([subjectId, deleted])
}

model Habit {
  id               Int            @id @default(autoincrement())
  name             String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  subjectId        Int?
  subject          Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  description      String         @default("")
  difficulty       difficulty     @default(MID)
  autoCompleteTime Int?
  badDayPlan       String?
  deleted          Boolean        @default(false)
  log              HabitTimeLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, deleted])
}

enum difficulty {
  HIGH
  MID
  LOW
}

model HabitTimeLog {
  id        Int       @id @default(autoincrement())
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  habit     Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  habitId   Int
  isBadDayPlan Boolean @default(false)
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([habitId])
  @@index([habitId, deleted])
}

model DailyRating {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Int // 1-5 scale
  description String?
  date        DateTime @default(now()) @db.Date

  @@unique([userId, date])
}

model Space {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  icon       String?
  order      Int      @default(0)
  isArchived Boolean  @default(false)
  deleted    Boolean  @default(false)
  columns    Column[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([userId, deleted])
}

model Column {
  id          Int      @id @default(autoincrement())
  spaceId     Int
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title       String
  order       Int      @default(0)
  width       Int?
  height      Int?
  isCollapsed Boolean  @default(false)
  deleted     Boolean  @default(false)
  blocks      Block[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([spaceId])
  @@index([spaceId, deleted])
}

enum BlockType {
  HEADING
  PARAGRAPH
  TODO
  DIVIDER
}

model Block {
  id       Int       @id @default(autoincrement())
  columnId Int
  column   Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  type     BlockType @default(TODO)
  content  String    @default("")
  order    Int       @default(0)
  deleted  Boolean   @default(false)

  isCompleted Boolean   @default(false)
  scheduledAt DateTime  @default(now())
  dueAt       DateTime?
  reminderAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([columnId])
  @@index([columnId, deleted])
}
