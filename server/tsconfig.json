{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "prisma/prismaClient.ts",
    "generated/prisma/client.js",
    "src/types/**/*.d.ts"
  ]
}
